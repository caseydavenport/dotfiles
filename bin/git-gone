#!/usr/bin/env bash
#
# git-gone: Delete local branches that are no longer needed.
#
# Two-pass hybrid approach:
#   1. Classic "gone" — branches whose remote tracking ref was pruned.
#   2. PR-merged — branches with a merged GitHub PR (catches untracked branches).
#
# Usage:
#   git gone          # list and prompt to delete
#   git gone -f       # delete without prompting
#   git gone --force  # same as -f

set -eo pipefail

force=false
if [[ "${1:-}" == "-f" || "${1:-}" == "--force" ]]; then
    force=true
fi

current_branch=$(git symbolic-ref --short HEAD 2>/dev/null || true)
default_branch=$(git symbolic-ref --short refs/remotes/origin/HEAD 2>/dev/null | sed 's|^origin/||' || echo "master")

declare -A to_delete  # branch -> reason

# --- Pass 1: Classic gone (tracking ref was pruned) ---
git fetch --all --prune --quiet 2>/dev/null

while IFS= read -r line; do
    branch=$(echo "$line" | awk '{print $1}')
    [[ -z "$branch" ]] && continue
    [[ "$branch" == "$current_branch" ]] && continue
    [[ "$branch" == "$default_branch" ]] && continue
    to_delete["$branch"]="tracking branch gone"
done < <(git branch -vv | grep ': gone]')

# --- Pass 2: Branches with merged PRs on GitHub ---
# Only runs if gh is available and we're in a GitHub repo.
if command -v gh &>/dev/null && gh repo view --json nameWithOwner &>/dev/null 2>&1; then
    repo=$(gh repo view --json nameWithOwner -q '.nameWithOwner')

    # Collect candidate branches (not already caught by pass 1, not current/default).
    candidates=()
    while IFS= read -r branch; do
        [[ -z "$branch" ]] && continue
        [[ "$branch" == "$current_branch" ]] && continue
        [[ "$branch" == "$default_branch" ]] && continue
        [[ -v "to_delete[$branch]" ]] && continue
        candidates+=("$branch")
    done < <(git for-each-ref --format='%(refname:short)' refs/heads/)

    if [[ ${#candidates[@]} -gt 0 ]]; then
        # Build search prefixes: each branch checked with and without fork owner prefixes.
        search_branches=()
        fork_owners=()
        for remote in $(git remote); do
            owner=$(git remote get-url "$remote" 2>/dev/null | sed -n 's|.*github.com[:/]\([^/]*\)/.*|\1|p')
            [[ -n "$owner" ]] && fork_owners+=("$owner")
        done

        for branch in "${candidates[@]}"; do
            search_branches+=("$branch")
        done

        # Batch GraphQL search in chunks to stay under query length limits.
        # Maps branch name -> PR number for merged PRs.
        declare -A merged_prs

        _search_merged_prs() {
            local query_terms=("$@")
            [[ ${#query_terms[@]} -eq 0 ]] && return

            local search_q="repo:${repo} is:pr is:merged"
            for term in "${query_terms[@]}"; do
                search_q+=" head:${term}"
            done

            local graphql_query
            graphql_query=$(cat <<GRAPHQL
query {
  search(query: "${search_q}", type: ISSUE, first: 100) {
    nodes {
      ... on PullRequest {
        number
        headRefName
      }
    }
  }
}
GRAPHQL
)
            local result
            result=$(gh api graphql -f query="$graphql_query" 2>/dev/null) || return 0

            # Parse results: extract number and headRefName pairs.
            while IFS= read -r line; do
                local pr_num head_ref
                pr_num=$(echo "$line" | sed -n 's/.*"number":\([0-9]*\).*/\1/p')
                head_ref=$(echo "$line" | sed -n 's/.*"headRefName":"\([^"]*\)".*/\1/p')
                if [[ -n "$pr_num" && -n "$head_ref" ]]; then
                    merged_prs["$head_ref"]="$pr_num"
                fi
            done < <(echo "$result" | tr '{}' '\n' | grep '"number"')
        }

        # Chunk branches into batches. Each "head:branch" term is ~10-50 chars;
        # keep total search query under ~200 chars of head terms to be safe.
        chunk=()
        chunk_len=0
        max_chunk_len=180

        for branch in "${search_branches[@]}"; do
            term_len=$(( ${#branch} + 6 ))  # "head:" + branch + space
            if (( chunk_len + term_len > max_chunk_len && ${#chunk[@]} > 0 )); then
                _search_merged_prs "${chunk[@]}"
                chunk=()
                chunk_len=0
            fi
            chunk+=("$branch")
            chunk_len=$(( chunk_len + term_len ))
        done
        [[ ${#chunk[@]} -gt 0 ]] && _search_merged_prs "${chunk[@]}"

        # If direct branch name didn't match, try with fork owner prefixes.
        # Only retry branches that weren't found in the first pass.
        remaining=()
        for branch in "${search_branches[@]}"; do
            [[ -v "merged_prs[$branch]" ]] || remaining+=("$branch")
        done

        if [[ ${#remaining[@]} -gt 0 && ${#fork_owners[@]} -gt 0 ]]; then
            for owner in "${fork_owners[@]}"; do
                prefixed=()
                for branch in "${remaining[@]}"; do
                    prefixed+=("${owner}:${branch}")
                done

                chunk=()
                chunk_len=0
                for term in "${prefixed[@]}"; do
                    term_len=$(( ${#term} + 6 ))
                    if (( chunk_len + term_len > max_chunk_len && ${#chunk[@]} > 0 )); then
                        _search_merged_prs "${chunk[@]}"
                        chunk=()
                        chunk_len=0
                    fi
                    chunk+=("$term")
                    chunk_len=$(( chunk_len + term_len ))
                done
                [[ ${#chunk[@]} -gt 0 ]] && _search_merged_prs "${chunk[@]}"
            done

            # Map prefixed results back to local branch names.
            for branch in "${remaining[@]}"; do
                for owner in "${fork_owners[@]}"; do
                    if [[ -v "merged_prs[${owner}:${branch}]" ]]; then
                        merged_prs["$branch"]="${merged_prs[${owner}:${branch}]}"
                        break
                    fi
                done
            done
        fi

        # Mark branches with merged PRs for deletion.
        for branch in "${candidates[@]}"; do
            if [[ -v "merged_prs[$branch]" ]]; then
                to_delete["$branch"]="https://github.com/${repo}/pull/${merged_prs[$branch]} merged"
            fi
        done
    fi
fi

# --- Output / Delete ---
if [[ ${#to_delete[@]} -eq 0 ]]; then
    echo "No gone branches found."
    exit 0
fi

_delete_branches() {
    for branch in $(echo "${!to_delete[@]}" | tr ' ' '\n' | sort); do
        reason="${to_delete[$branch]}"
        git branch -D "$branch"
        echo "  ($reason)"
    done
}

if [[ "$force" == true ]]; then
    _delete_branches
else
    echo "Branches to delete:"
    echo ""
    for branch in $(echo "${!to_delete[@]}" | tr ' ' '\n' | sort); do
        reason="${to_delete[$branch]}"
        printf "  %-45s %s\n" "$branch" "($reason)"
    done
    echo ""
    read -rp "Delete these branches? [y/N] " confirm
    if [[ "$confirm" =~ ^[Yy]$ ]]; then
        _delete_branches
    else
        echo "Aborted."
    fi
fi
