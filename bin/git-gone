#!/usr/bin/env bash
#
# git-gone: Delete local branches that are no longer needed.
#
# Two-pass hybrid approach:
#   1. Classic "gone" — branches whose remote tracking ref was pruned.
#   2. PR-merged — branches with a merged GitHub PR (catches untracked branches).
#
# Usage:
#   git gone          # list and prompt to delete
#   git gone -f       # delete without prompting
#   git gone --force  # same as -f

set -eo pipefail

force=false
if [[ "${1:-}" == "-f" || "${1:-}" == "--force" ]]; then
    force=true
fi

current_branch=$(git symbolic-ref --short HEAD 2>/dev/null || true)
default_branch=$(git symbolic-ref --short refs/remotes/origin/HEAD 2>/dev/null | sed 's|^origin/||' || echo "master")

declare -A to_delete  # branch -> reason

# --- Pass 1: Classic gone (tracking ref was pruned) ---
# Fetch each remote individually so one unreachable remote doesn't abort the script.
for _remote in $(git remote); do
    git fetch "$_remote" --prune --quiet 2>/dev/null || true
done

while IFS= read -r line; do
    # Strip leading markers: "* " (current), "+ " (worktree), "  " (normal).
    branch=$(echo "$line" | sed 's/^[* +]*//' | awk '{print $1}')
    [[ -z "$branch" ]] && continue
    [[ "$branch" == "$current_branch" ]] && continue
    [[ "$branch" == "$default_branch" ]] && continue
    to_delete["$branch"]="tracking branch gone"
done < <(git branch -vv | grep ': gone]')

# --- Pass 2: Branches with merged PRs on GitHub ---
# Only runs if gh is available and we're in a GitHub repo.
if command -v gh &>/dev/null && gh repo view --json nameWithOwner &>/dev/null 2>&1; then
    repo=$(gh repo view --json nameWithOwner -q '.nameWithOwner')

    # Collect candidate branches (not already caught by pass 1, not current/default).
    candidates=()
    while IFS= read -r branch; do
        [[ -z "$branch" ]] && continue
        [[ "$branch" == "$current_branch" ]] && continue
        [[ "$branch" == "$default_branch" ]] && continue
        [[ -v "to_delete[$branch]" ]] && continue
        candidates+=("$branch")
    done < <(git for-each-ref --format='%(refname:short)' refs/heads/)

    if [[ ${#candidates[@]} -gt 0 ]]; then
        fork_owners=()
        for remote in $(git remote); do
            owner=$(git remote get-url "$remote" 2>/dev/null | sed -n 's|.*github.com[:/]\([^/]*\)/.*|\1|p')
            [[ -n "$owner" ]] && fork_owners+=("$owner")
        done

        declare -A merged_prs  # branch -> PR number

        # Use GraphQL aliases to check multiple branches in one HTTP request.
        # Each alias runs an independent search, avoiding the GitHub search
        # limitation where multiple head: qualifiers are ANDed together.
        _batch_search() {
            local -a head_refs=("$@")
            [[ ${#head_refs[@]} -eq 0 ]] && return

            local query="query {"
            local i=0
            for ref in "${head_refs[@]}"; do
                # Sanitize branch name for use in GraphQL string (escape quotes).
                local safe_ref="${ref//\"/\\\"}"
                query+="
  b${i}: search(query: \"repo:${repo} is:pr is:merged head:${safe_ref}\", type: ISSUE, first: 1) {
    nodes { ... on PullRequest { number headRefName } }
  }"
                i=$(( i + 1 ))
            done
            query+=$'\n}'

            local result
            result=$(gh api graphql -f query="$query" 2>/dev/null) || return 0

            # Extract number/headRefName pairs from all aliases.
            while IFS=$'\t' read -r pr_num head_ref; do
                [[ -n "$pr_num" && -n "$head_ref" ]] && merged_prs["$head_ref"]="$pr_num"
            done < <(echo "$result" | jq -r '
                .data | to_entries[].value.nodes[]? |
                "\(.number)\t\(.headRefName)"
            ' 2>/dev/null)
        }

        # Batch in chunks of 15 to stay within GraphQL complexity limits.
        chunk=()
        for branch in "${candidates[@]}"; do
            chunk+=("$branch")
            if [[ ${#chunk[@]} -ge 15 ]]; then
                _batch_search "${chunk[@]}"
                chunk=()
            fi
        done
        [[ ${#chunk[@]} -gt 0 ]] && _batch_search "${chunk[@]}"

        # Retry unmatched branches with fork owner prefixes (e.g., caseydavenport:branch).
        remaining=()
        for branch in "${candidates[@]}"; do
            [[ -v "merged_prs[$branch]" ]] || remaining+=("$branch")
        done

        if [[ ${#remaining[@]} -gt 0 && ${#fork_owners[@]} -gt 0 ]]; then
            for owner in "${fork_owners[@]}"; do
                prefixed=()
                for branch in "${remaining[@]}"; do
                    prefixed+=("${owner}:${branch}")
                done

                chunk=()
                for term in "${prefixed[@]}"; do
                    chunk+=("$term")
                    if [[ ${#chunk[@]} -ge 15 ]]; then
                        _batch_search "${chunk[@]}"
                        chunk=()
                    fi
                done
                [[ ${#chunk[@]} -gt 0 ]] && _batch_search "${chunk[@]}"
            done

            # Map prefixed results back to local branch names.
            for branch in "${remaining[@]}"; do
                for owner in "${fork_owners[@]}"; do
                    if [[ -v "merged_prs[${owner}:${branch}]" ]]; then
                        merged_prs["$branch"]="${merged_prs[${owner}:${branch}]}"
                        break
                    fi
                done
            done
        fi

        # Mark branches with merged PRs for deletion.
        for branch in "${candidates[@]}"; do
            if [[ -v "merged_prs[$branch]" ]]; then
                to_delete["$branch"]="https://github.com/${repo}/pull/${merged_prs[$branch]} merged"
            fi
        done
    fi
fi

# --- Output / Delete ---
if [[ ${#to_delete[@]} -eq 0 ]]; then
    echo "No gone branches found."
    exit 0
fi

_delete_branches() {
    for branch in $(echo "${!to_delete[@]}" | tr ' ' '\n' | sort); do
        reason="${to_delete[$branch]}"
        git branch -D "$branch"
        echo "  ($reason)"
    done
}

if [[ "$force" == true ]]; then
    _delete_branches
else
    echo "Branches to delete:"
    echo ""
    for branch in $(echo "${!to_delete[@]}" | tr ' ' '\n' | sort); do
        reason="${to_delete[$branch]}"
        printf "  %-45s %s\n" "$branch" "($reason)"
    done
    echo ""
    read -rp "Delete these branches? [y/N] " confirm
    if [[ "$confirm" =~ ^[Yy]$ ]]; then
        _delete_branches
    else
        echo "Aborted."
    fi
fi
