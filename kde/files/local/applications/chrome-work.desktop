[Desktop Entry]
Version=1.0
Name=Chrome (Work)
GenericName=Web Browser
Comment=Google Chrome — Work profile (casey@tigera.io)
Exec=/usr/bin/google-chrome-stable --user-data-dir=/home/casey/.config/google-chrome-work --class=chrome-work %U
Icon=/home/casey/.local/share/icons/chrome-work.png
Terminal=false
Type=Application
Categories=Network;WebBrowser;
MimeType=text/html;text/xml;application/xhtml+xml;x-scheme-handler/http;x-scheme-handler/https;
StartupNotify=true
StartupWMClass=chrome-work
