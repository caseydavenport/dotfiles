[core]
	editor = vim
[user]
	name = Casey Davenport
	email = davenport.cas@gmail.com
[color]
	ui = true
[pager]
	branch = false
	diff = delta
	log = delta
	reflog = delta
	show = delta
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
	side-by-side = true
	line-numbers = true
	syntax-theme = Catppuccin Mocha
	dark = true
[url "ssh://git@github.com/"]
	insteadOf = https://github.com/
[hub]
	protocol = ssh
